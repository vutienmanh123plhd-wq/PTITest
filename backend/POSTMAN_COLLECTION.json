    {
      "name": "Admin - Exams",
      "item": [
        {
          "name": "Create Exam",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{admin_token}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Final Exam\",\n  \"description\": \"Final examination for the course\",\n  \"type\": \"final\",\n  \"status\": \"available\",\n  \"duration\": 120,\n  \"questions\": [\n    {\n      \"question\": \"Sample question 1?\",\n      \"options\": [\n        {\"option_text\": \"Option A\", \"is_correct\": false},\n        {\"option_text\": \"Option B\", \"is_correct\": true},\n        {\"option_text\": \"Option C\", \"is_correct\": false},\n        {\"option_text\": \"Option D\", \"is_correct\": false}\n      ]\n    },\n    {\n      \"question\": \"Sample question 2?\",\n      \"options\": [\n        {\"option_text\": \"Answer 1\", \"is_correct\": false},\n        {\"option_text\": \"Answer 2\", \"is_correct\": false},\n        {\"option_text\": \"Answer 3\", \"is_correct\": true},\n        {\"option_text\": \"Answer 4\", \"is_correct\": false}\n      ]\n    }\n  ]\n}"
            },
            "url": {
              "raw": "{{base_url}}/admin/exams",
              "host": ["{{base_url}}"],
              "path": ["admin", "exams"]
            }
          }
        },
        {
          "name": "Update Exam",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{admin_token}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Updated Exam Name\",\n  \"status\": \"closed\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/admin/exams/{{exam_id}}",
              "host": ["{{base_url}}"],
              "path": ["admin", "exams", "{{exam_id}}"]
            }
          }
        },
        {
          "name": "Delete Exam",
          "request": {
            "method": "DELETE",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{admin_token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/admin/exams/{{exam_id}}",
              "host": ["{{base_url}}"],
              "path": ["admin", "exams", "{{exam_id}}"]
            }
          }
        }
